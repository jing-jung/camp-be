environment = "dev"
aws_region  = "ap-northeast-2"

api_lambda_package_path = "../../dist/stockbrief-api-lambda.zip"
cors_allowed_origins    = "http://localhost:3000,http://127.0.0.1:3000"
chat_provider           = "mock"
bedrock_chat_model_id   = "apac.amazon.nova-micro-v1:0"
bedrock_chat_region     = ""
bedrock_chat_inference_profile_foundation_model_regions = [
  "ap-southeast-2",
  "ap-northeast-1",
  "ap-south-1",
  "ap-northeast-2",
  "ap-southeast-1",
  "ap-northeast-3",
]
bedrock_chat_inference_profile_extra_foundation_model_arns = []

enable_amplify         = false
amplify_repository_url = "https://github.com/example/StockBrief-fe"
amplify_branch_name    = "main"
# After Amplify default_domain is known, set this to the hosted callback URL.
amplify_cognito_redirect_uri = ""
# Provide a real token via TF_VAR_amplify_access_token, not in this file.

cognito_callback_urls           = ["http://localhost:3000/auth/callback"]
cognito_logout_urls             = ["http://localhost:3000/account"]
cognito_hosted_ui_domain_prefix = ""

db_instance_class          = "db.t4g.micro"
db_allocated_storage_gb    = 20
db_deletion_protection     = false
db_skip_final_snapshot     = true
db_backup_retention_period = 1

# Fill these after the dev VPC/subnets/security groups are chosen.
db_subnet_ids                = []
db_security_group_ids        = []
rds_proxy_security_group_ids = []
enable_rds_proxy            = false
lambda_subnet_ids            = []
lambda_security_group_ids    = []
vpc_endpoint_route_table_ids = []
enable_lambda_nat_egress     = false
lambda_nat_public_subnet_id  = ""
lambda_nat_route_subnet_ids  = []

enable_operational_alarms       = true
operational_alarm_email_addresses = []

agentcore_runtime_enabled       = false
agentcore_runtime_container_uri = ""
agentcore_network_mode          = "PUBLIC"

enable_ingestion_raw_archive        = true
ingestion_raw_retention_days        = 30
enable_ingestion_scheduler          = false
ingestion_schedule_expression       = "cron(0 18 ? * MON-FRI *)"
ingestion_schedule_provider         = "OpenDART"
ingestion_schedule_tickers          = []
ingestion_schedule_jobs             = []
ingestion_dlq_message_retention_seconds = 1209600
