environment = "prod"
aws_region  = "ap-northeast-2"

api_lambda_package_path = "../../dist/stockbrief-api-lambda.zip"
cors_allowed_origins    = "https://stockbrief.example.com"

enable_amplify         = false
amplify_repository_url = "https://github.com/example/StockBrief-fe"
amplify_branch_name    = "main"
# After Amplify default_domain is known, set this to the hosted callback URL.
amplify_cognito_redirect_uri = ""
# Provide a real token via TF_VAR_amplify_access_token, not in this file.

cognito_callback_urls           = ["https://stockbrief.example.com/auth/callback"]
cognito_logout_urls             = ["https://stockbrief.example.com/account"]
cognito_hosted_ui_domain_prefix = ""

db_instance_class          = "db.t4g.medium"
db_allocated_storage_gb    = 100
db_deletion_protection     = true
db_skip_final_snapshot     = false
db_backup_retention_period = 7
enable_rds_proxy           = true

db_subnet_ids             = []
db_security_group_ids     = []
lambda_subnet_ids         = []
lambda_security_group_ids = []

enable_operational_alarms       = true
operational_alarm_email_addresses = []

agentcore_runtime_enabled       = false
agentcore_runtime_container_uri = ""
agentcore_network_mode          = "PUBLIC"
