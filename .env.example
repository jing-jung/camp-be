# StockBrief-be local development environment template.
# Do not put real API keys, tokens, passwords, or production secrets in this file.

# Runtime
APP_ENV=local
LOG_LEVEL=info

# Backend
SERVICE_NAME=stockbrief-api
SERVICE_VERSION=0.1.0
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_PATH=/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=postgresql+psycopg://stockbrief:stockbrief@localhost:5432/stockbrief
DATABASE_SECRET_ARN=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=stockbrief
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_POOL_TIMEOUT_SECONDS=30

# Public data providers
OPENDART_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Cognito auth (backend)
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_ISSUER=
COGNITO_JWKS_URL=

# Optional fallback or seed data provider
KRX_DATA_PATH=
